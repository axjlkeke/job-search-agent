<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tokensoff.kb-sync</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PROJECT_DIR__/infra/macmini/run-kb-sync.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>4</integer>
    <key>Minute</key>
    <integer>10</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__LOG_DIR__/kb-sync.log</string>
  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/kb-sync.error.log</string>
</dict>
</plist>
