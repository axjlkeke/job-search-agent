# 复制为 env.local 后修改。env.local 已被 Git 忽略，不要把密钥发到群里或提交到 GitHub。

# 从开发电脑远程部署时填 SSH 别名（推荐先在 ~/.ssh/config 中配好）。
# 如果脚本就在 Mac mini 上执行，可以留空。
DEPLOY_TARGET=""

# Mac mini 上的项目目录。请把 your-name 换成 Mac mini 当前用户名。
APP_REPO_DIR="/Users/your-name/Services/job-search-agent"

# 所有后台服务默认只绑定 127.0.0.1，不直接暴露到局域网或公网。
APP_HOST="127.0.0.1"
APP_PORT="3000"
KB_HOST="127.0.0.1"
KB_PORT="8001"
KB_HEALTH_PATH="/health"
KB_SYNC_SOURCE_LIMIT="20"
KB_DIFY_RECONCILE_LIMIT="200"
# 当前 Mac mini 使用透明代理的 fake-IP DNS；只有已审核 allowed_hosts 的来源可放行。
KB_ALLOW_FAKE_IP_DNS="true"
# 可选；只有确认本机代理端口正在监听时才填写，例如 http://127.0.0.1:7897。
KB_PROXY_URL=""
KB_TESSERACT_PATH="/opt/homebrew/bin/tesseract"
KB_TESSDATA_DIR="$HOME/.local/share/tokensoff/tessdata"
KB_VISION_OCR_PATH="$HOME/.local/bin/tokensoff-vision-ocr"
KB_OCR_TIMEOUT_SECONDS="90"
KB_OCR_MAX_IMAGES="3"
KB_OCR_TRIGGER_CHARS="200"
PREPARE_KB_OCR="true"
OLLAMA_HOST="127.0.0.1:11434"
OLLAMA_MODEL="qwen3-embedding:0.6b"
DIFY_LLM_MODEL="qwen2.5:1.5b"

# KB 服务的默认位置和启动入口。如果业务实现使用了其他路径，只改这两项。
KB_WORKDIR="/Users/your-name/Services/job-search-agent/services/knowledge-base"
KB_APP_MODULE="app.main:app"
KB_DATA_DIR="$HOME/.local/share/tokensoff/kb"
KB_DB_PATH="$HOME/.local/share/tokensoff/kb/knowledge.db"

# 现有业务接口。
ZHIDA_TRPC_URL="https://www.zhidasihai.cn/api/trpc"
RAG_API_URL="http://127.0.0.1:8001/search"
# 这两项必须使用同一个值：一个给 KB 验证，一个给前端调用。
# 都留空时，deploy.sh 会在服务器首次生成并持久化同一个强随机值。
KB_API_KEY=""
RAG_API_KEY="$KB_API_KEY"
DIFY_API_URL="http://127.0.0.1:8000/v1"
# Dify 中创建知识库后填这两项，供 KB 同步和检索。
DIFY_DATASET_ID=""
DIFY_DATASET_API_KEY=""
# Dify 聊天应用的 API Key，与 Dataset Key 分开。
DIFY_API_KEY=""
# 留空时同样由 deploy.sh 在首次部署时生成，不会打印。
ADVISOR_SESSION_SECRET=""
ADVISOR_ALLOW_ANONYMOUS_PUBLIC_KB="false"

# 主站资料/权益一次性接力。正式启用前必须先完成主站侧审批和联调。
# 两个端点必须同属一个 HTTPS origin；都留空时前端保持手工建档。
ZHIDA_AGENT_AUTHORIZE_URL=""
ZHIDA_AGENT_EXCHANGE_URL=""
# 留空时 deploy.sh 在服务器首次生成并持久化，只用于本项目 Cookie 加密。
ZHIDA_AGENT_SESSION_SECRET=""
ZHIDA_AGENT_AUDIENCE="job-search-agent"

# Colima 在 Mac mini 16G 上的保守配置。Docker 已可用时不会重复启动 Colima。
COLIMA_CPU="4"
COLIMA_MEMORY_GB="8"
COLIMA_DISK_GB="30"
START_CONTAINER_ENGINE="true"

# Dify 固定到经过验证的 1.15.0，只在 127.0.0.1:8000 上提供服务。
DIFY_VERSION="1.15.0"
DIFY_ROOT_DIR="$HOME/Services/dify"
DIFY_BIND_ADDRESS="127.0.0.1"
DIFY_PORT="8000"
DIFY_SSL_PORT="8443"
DIFY_PLUGIN_DEBUG_PORT="5003"
START_DIFY="true"

# 以下值留空时，prepare-dify.sh 会在 Mac mini 本机首次生成并保存，以后部署会沿用。
# 生成的值只会进入 Dify docker/.env（权限 600），不会打印、回传或写进 Git。
# 如果你有自己的密钥，也可以在这里显式填入。
DIFY_SECRET_KEY=""
DIFY_DB_PASSWORD=""
DIFY_REDIS_PASSWORD=""
DIFY_PLUGIN_DAEMON_KEY=""
DIFY_PLUGIN_INNER_API_KEY=""
DIFY_QDRANT_API_KEY=""

# Cloudflare Tunnel。首次需要在 Mac mini 上完成一次授权和 tunnel 创建。
# Tunnel 只把 tokensoff.com 转到前端 3000 端口，不转发 Dify/RAG。
ENABLE_CLOUDFLARE_TUNNEL="false"
PUBLIC_HOSTNAME="tokensoff.com"
CLOUDFLARE_TUNNEL_NAME="tokensoff-macmini"
CLOUDFLARE_TUNNEL_ID=""
CLOUDFLARE_CREDENTIALS_FILE="$HOME/.cloudflared/replace-with-tunnel-id.json"
CLOUDFLARE_CONFIG_FILE="$HOME/.cloudflared/config.yml"

# 部署开关。
RUN_SETUP_ON_DEPLOY="true"
INSTALL_LAUNCH_AGENTS="true"
PULL_OLLAMA_MODEL="true"

# 日志和备份。
LOG_DIR="$HOME/Library/Logs/tokensoff"
BACKUP_DIR="$HOME/Backups/tokensoff"
BACKUP_RETENTION_DAYS="14"
DIFY_DB_USER="postgres"
DIFY_DB_NAME="dify"
