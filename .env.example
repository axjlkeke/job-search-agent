# 这些变量只允许在服务端使用，不要暴露到浏览器。

# 职达现有 tRPC：读取在招岗位与在线产品目录。默认值如下，可不填写。
ZHIDA_TRPC_URL=https://www.zhidasihai.cn/api/trpc

# 独立职业情报只读 API。只允许服务端调用，不要暴露到浏览器。
CAREER_INTELLIGENCE_API_URL=http://127.0.0.1:18080

# 现有知识库检索接口。约定 POST { query, topK }，返回 results/records/items。
RAG_API_URL=http://localhost:8001/search
RAG_API_KEY=

# Dify 应用 API 基址（通常以 /v1 结尾）与应用密钥。
DIFY_API_URL=http://localhost:8000/v1
DIFY_API_KEY=

# 至少 32 位，用于签名匿名会话；未配置时顾问接口保持关闭。
ADVISOR_SESSION_SECRET=

# 默认 false。只有知识库全部为可公开资料时，才可显式开启匿名本地测试。
# 含简历、求职案例或内部资料时不要开启，应先接入真实登录与访问授权。
ADVISOR_ALLOW_ANONYMOUS_PUBLIC_KB=false

# 主站资料与权益接力。正式环境必须是同一个 HTTPS 来源；以下仅示意本机模拟器。
# 未完整配置时功能自动关闭，不影响手工建档，也不会读取主站登录 Cookie。
ZHIDA_AGENT_AUTHORIZE_URL=
ZHIDA_AGENT_EXCHANGE_URL=
ZHIDA_AGENT_SESSION_SECRET=
ZHIDA_AGENT_AUDIENCE=job-search-agent
