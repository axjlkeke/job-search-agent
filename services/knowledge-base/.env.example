# SQLite 是原始资料、版本和审核队列的事实库；目录会自动创建。
KB_DATABASE_PATH=./data/knowledge.db

# 可选。填写后，除 /health 外的接口都必须携带 Authorization: Bearer <key>。
KB_API_KEY=

# 三项全部填写后，来源变化会同步 Dify 文档，/search 优先代理 Dataset Retrieval API。
# Dify 写入失败进入审核队列；检索失败会回退本地 FTS5。
DIFY_API_URL=http://127.0.0.1:8000/v1
DIFY_DATASET_ID=
DIFY_DATASET_API_KEY=
DIFY_TIMEOUT_SECONDS=12

FETCH_TIMEOUT_SECONDS=20
MAX_FETCH_BYTES=10485760
KB_USER_AGENT=JobSearchAgentKnowledgeBot/0.1 (+public-recruitment-research)
# 仅当 Mac 使用透明代理的 198.18.0.0/15 fake-IP DNS 时开启；抓取仍受来源 allowed_hosts 限制。
KB_ALLOW_FAKE_IP_DNS=false
# 可选且只允许指向本机，用于 Mac 透明代理环境中的稳定官网抓取。
KB_PROXY_URL=

# 可选图片正文 OCR。Mac mini 使用私有 tessdata 目录，不需要改系统包。
# macOS 可由 prepare-kb-ocr.sh 编译 Vision OCR，并优先使用；留空时使用 Tesseract。
KB_VISION_OCR_PATH=
KB_TESSERACT_PATH=
KB_TESSDATA_DIR=
KB_OCR_TIMEOUT_SECONDS=90
KB_OCR_MAX_IMAGES=3
KB_OCR_TRIGGER_CHARS=200
